{
	"name": "vega",
	"private": true,
	"version": "0.0.1",
	"license": "MIT",
	"type": "module",
	"packageManager": "pnpm@11.11.0",
	"scripts": {
		"predev": "pnpm themes:build",
		"dev": "vite dev",
		"prebuild": "pnpm themes:build",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint . && pnpm themes:check-coverage",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "vitest run",
		"pb:download": "node scripts/download-pocketbase.mjs",
		"test:pb": "node scripts/download-pocketbase.mjs && vitest run tests/contract/pocketbase.contract.test.ts",
		"test:e2e": "playwright test",
		"themes:build": "node scripts/build-themes.mjs",
		"themes:check-coverage": "node scripts/check-theme-coverage.mjs",
		"gate": "pnpm check && pnpm lint && pnpm test && pnpm build && pnpm test:e2e"
	},
	"dependencies": {
		"@tiptap/core": "^3.28.0",
		"@tiptap/extension-image": "^3.28.0",
		"@tiptap/extension-link": "^3.28.0",
		"@tiptap/markdown": "^3.28.0",
		"@tiptap/pm": "^3.28.0",
		"@tiptap/starter-kit": "^3.28.0",
		"pocketbase": "^0.27.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^22",
		"ajv": "^8.20.0",
		"dompurify": "^3.4.12",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"eventsource": "^4.1.0",
		"globals": "^17.6.0",
		"jsdom": "29.1.1",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	}
}
