node_modules

# Git worktrees efímeros de agentes (Claude Code): checkouts aislados con sus propios
# .svelte-kit/build; nunca se commitean y no deben entrar al lint/prettier del árbol principal.
.claude/worktrees/

# Output
.output
.vercel
.netlify
.wrangler
/.svelte-kit
/build

# OS
.DS_Store
Thumbs.db

# Env
.env
.env.*
!.env.example
!.env.test

# Vite
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Zip de distribución (`pnpm package`, scripts/package-dist.mjs): artefacto local, nunca se
# commitea (el release oficial por tag lo publica `release.yml` como asset de GitHub Release).
/dist

# Binario de PocketBase para la suite de contrato real (Fase 2, tests/contract/pb-harness/):
# se descarga con `pnpm test:pb` / `scripts/download-pocketbase.mjs`, nunca se commitea.
/.pbbin
# Datos efímeros de instancias de PocketBase levantadas por el harness de tests.
/.pbdata-*

# Salida de Playwright (§7.B del contrato P3, `pnpm test:e2e`): informes/trazas de ejecuciones
# locales, nunca se commitean.
/test-results
/playwright-report
/blob-report
