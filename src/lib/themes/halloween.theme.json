{
	"$schema": "./theme.schema.json",
	"themeSchemaVersion": 1,
	"id": "halloween",
	"name": "Halloween",
	"group": "calidos",
	"roles": {
		"tint": "#7a3fa0",
		"accent": "#ef7a26",
		"accentInk": "#201206"
	},
	"derived": {
