{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://vega.dev/theme.schema.json",
	"title": "Tema de Vega v2",
	"description": "Un tema = src/lib/themes/<id>.theme.json. Papel (tint) desacoplado del acento (accent); neutros compartidos + tinte por defecto, override final opcional por tema; efectos visuales portados del catálogo de Lumbre mediante slots semánticos.",
	"type": "object",
	"additionalProperties": false,
	"required": ["themeSchemaVersion", "id", "name", "group", "roles"],
	"properties": {
		"$schema": { "type": "string" },
		"themeSchemaVersion": { "const": 1 },
		"id": {
			"description": "Clave estable persistida (localStorage.vega.theme). Nunca se borra.",
			"type": "string",
			"minLength": 1
		},
		"name": {
			"description": "Etiqueta visible en el selector de P3.",
			"type": "string",
			"minLength": 1
		},
		"group": {
			"description": "Agrupación del selector (D-P7.1, enum propio de Vega).",
			"enum": ["frios", "calidos", "neutros", "verdes", "pastel-firma-mono", "iridiscentes"]
		},
		"aliases": {
			"description": "Ids antiguos que migran a este (nunca se borran, forward-compat de ids renombrados, §6.4).",
			"type": "array",
			"items": { "type": "string", "minLength": 1 },
			"uniqueItems": true
		},
		"roles": {
			"description": "Lo ÚNICO que el tema escribe de color (§2). SIN date/deadline/done (vocabulario de tareas de Lumbre, no portable).",
			"type": "object",
			"additionalProperties": false,
			"required": ["tint", "accent", "accentInk"],
			"properties": {
				"tint": {
					"description": "Matiz del papel (independiente de accent, L4 papel ⊥ acento).",
					"$ref": "#/$defs/hexColor"
				},
				"accent": { "description": "Marca.", "$ref": "#/$defs/hexColor" },
				"accentInk": {
					"description": "Texto sobre relleno de marca. AA ≥4.5 sobre accent (gate §5.3).",
					"$ref": "#/$defs/hexColor"
				},
				"accentText": {
					"description": "OPCIONAL: acento-como-texto. Default = derivado §4.3; si se declara, AA ≥4.5 sobre paper/surface/surface-2 (gate §5.3).",
					"$ref": "#/$defs/hexColor"
				}
			}
		},
		"derived": {
			"description": "Overrides visuales expresados en CSS; el generador solo admite estos dos slots cerrados.",
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"accentSoft": { "$ref": "#/$defs/paperMix" },
				"accentLine": { "$ref": "#/$defs/lineMix" }
			}
		},
		"modes": {
			"description": "OPCIONAL: overrides por modo (§4.4, escape hatch Opción A de Lumbre).",
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"light": { "$ref": "#/$defs/modeOverride" },
				"dark": { "$ref": "#/$defs/modeOverride" }
			}
		},
		"effects": {
			"description": "Pinturas de marca opcionales. Ausente equivale al acento sólido.",
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"fillGrad": { "$ref": "#/$defs/gradient" },
				"strokeGrad": { "$ref": "#/$defs/gradient" },
				"halo": {
					"type": "array",
					"minItems": 1,
					"maxItems": 3,
					"items": { "$ref": "#/$defs/radial" }
				},
				"brandStops": {
					"type": "array",
					"minItems": 3,
					"maxItems": 3,
					"items": { "$ref": "#/$defs/hexColor" }
				},
				"edgeOpacity": { "type": "number", "minimum": 0, "maximum": 1 },
				"slots": {
					"type": "object",
					"additionalProperties": false,
					"properties": {
						"fill": { "type": "string", "enum": ["fillGrad", "strokeGrad"] }
					}
				}
			}
		}
	},
	"$defs": {
		"hexColor": {
			"type": "string",
			"pattern": "^#([0-9a-fA-F]{3}|[0-9a-fA-F]{6})$"
		},
		"percent": {
			"type": "string",
			"pattern": "^-?[0-9]+(\\.[0-9]+)?%$"
		},
		"mixWeightPercent": {
			"description": "Peso CSS de mezcla, acotado a 0–100 %. No confundir con una posición de gradiente, que puede quedar fuera de ese rango.",
			"type": "string",
			"pattern": "^(100(\\.0+)?|([0-9]|[1-9][0-9])(\\.[0-9]+)?)%$"
		},
		"paperMix": {
			"type": "string",
			"pattern": "^color-mix\\(in oklab,\\s*#[0-9a-fA-F]{6}\\s+(100(\\.0+)?|([0-9]|[1-9][0-9])(\\.[0-9]+)?)%,\\s*var\\(--paper\\)\\)$"
		},
		"lineMix": {
			"type": "string",
			"pattern": "^color-mix\\(in oklab,\\s*#[0-9a-fA-F]{6}\\s+(100(\\.0+)?|([0-9]|[1-9][0-9])(\\.[0-9]+)?)%,\\s*var\\(--line\\)\\)$"
		},
		"gradientStop": {
			"type": "object",
			"additionalProperties": false,
			"required": ["color", "at"],
			"properties": {
				"color": { "$ref": "#/$defs/hexColor" },
				"at": { "$ref": "#/$defs/percent" }
			}
		},
		"gradient": {
			"type": "object",
			"additionalProperties": false,
			"required": ["angle", "stops"],
			"properties": {
				"angle": { "type": "number" },
				"stops": {
					"type": "array",
					"minItems": 2,
					"items": { "$ref": "#/$defs/gradientStop" }
				}
			}
		},
		"radial": {
			"oneOf": [
				{
					"type": "object",
					"additionalProperties": false,
					"required": ["size", "at", "color", "alpha", "extent"],
					"properties": {
						"size": { "type": "string", "minLength": 1 },
						"at": { "type": "string", "minLength": 1 },
						"color": { "$ref": "#/$defs/hexColor" },
						"alpha": { "$ref": "#/$defs/mixWeightPercent" },
						"extent": { "$ref": "#/$defs/percent" }
					}
				},
				{
					"type": "object",
					"additionalProperties": false,
					"required": ["css"],
					"properties": { "css": { "type": "string", "minLength": 1 } }
				}
			]
		},
		"modeOverride": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"tintBg": {
					"description": "Pisa el porcentaje de tinte del bucket `bg` para este modo (§4.3).",
					"$ref": "#/$defs/mixWeightPercent"
				},
				"neutrals": {
					"description": "Override final por neutro (§4.4): gana por especificidad, se pinta TAL CUAL sin re-tintar. Guardarraíles: escala de luminancia ascendente + AA de ink sobre paper si se pisa ink (validateNeutrals).",
					"type": "object",
					"additionalProperties": false,
					"properties": {
						"bg": { "$ref": "#/$defs/hexColor" },
						"sidebar": { "$ref": "#/$defs/hexColor" },
						"paper": { "$ref": "#/$defs/hexColor" },
						"surface": { "$ref": "#/$defs/hexColor" },
						"surface-2": { "$ref": "#/$defs/hexColor" },
						"btn": { "$ref": "#/$defs/hexColor" },
						"active": { "$ref": "#/$defs/hexColor" },
						"line": { "$ref": "#/$defs/hexColor" },
						"line-soft": { "$ref": "#/$defs/hexColor" },
						"line-strong": { "$ref": "#/$defs/hexColor" },
						"ring": { "$ref": "#/$defs/hexColor" },
						"ink-hi": { "$ref": "#/$defs/hexColor" },
						"ink": { "$ref": "#/$defs/hexColor" },
						"ink-2": { "$ref": "#/$defs/hexColor" },
						"ink-3": { "$ref": "#/$defs/hexColor" }
					}
				}
			}
		}
	}
}
